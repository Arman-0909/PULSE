# Pulse Configuration
# Copy this to .env and fill in your values

# Database (use SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./pulse.db
# DATABASE_URL=postgresql://user:password@localhost:5432/pulse

# Auth
SECRET_KEY=change-this-to-a-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Monitoring
CHECK_INTERVAL=30
REQUEST_TIMEOUT=5
